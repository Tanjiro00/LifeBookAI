{
  "name": "lifebook-bot",
  "version": "0.1.0",
  "private": true,
  "description": "LifeBook Bot MVP: Telegram bot that turns weekly text or voice updates into private autobiographical chapters.",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:bot": "tsx watch apps/bot/src/index.ts",
    "dev:web": "npm --workspace @lifebook/web run dev",
    "build": "npm run build --workspaces --if-present",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.base.json --noEmit",
    "prisma:generate": "prisma generate --schema packages/db/prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema packages/db/prisma/schema.prisma",
    "prisma:studio": "prisma studio --schema packages/db/prisma/schema.prisma"
  },
  "overrides": {
    "postcss": "^8.5.14"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "prisma": "^6.19.3",
    "tsx": "^4.20.0",
    "typescript": "^5.8.3",
    "vitest": "^3.1.2"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "@sentry/node": "^10.52.0",
    "prom-client": "^15.1.3"
  }
}
