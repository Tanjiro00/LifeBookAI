# Runtime
NODE_ENV=development
LOG_LEVEL=info
PUBLIC_WEB_URL=http://localhost:3000
VITE_API_BASE_URL=http://localhost:8080
BOT_WEBHOOK_URL=
BOT_MODE=polling
PORT=8080

# Telegram
TELEGRAM_BOT_TOKEN=123456:replace-me
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_PROVIDER_TOKEN=

# Database / queues
DATABASE_URL=postgresql://lifebook:lifebook@localhost:5432/lifebook?schema=public
REDIS_URL=redis://localhost:6379

# OpenAI. Required — there is no mock fallback. Bot will throw on first AI call without it.
OPENAI_API_KEY=
OPENAI_TEXT_MODEL=gpt-4.1-mini
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSIONS=1536
OPENAI_PLANNER_MODEL=gpt-4.1-mini
OPENAI_WRITER_MODEL=gpt-4.1
OPENAI_VALIDATOR_MODEL=gpt-4.1-mini
AI_PROVIDER=openai

# Mini App (Sprint 0+). Empty MINIAPP_URL falls back to PUBLIC_WEB_URL.
MINIAPP_URL=
MINIAPP_JWT_SECRET=
MINIAPP_JWT_TTL_SECONDS=3600
WORKER_ENABLED=true

# Storage. Local storage is used by default for MVP development.
STORAGE_DRIVER=local
LOCAL_STORAGE_DIR=./storage
S3_ENDPOINT=
S3_REGION=auto
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# Product limits
FREE_CHAPTER_LIMIT=3
FREE_PAGE_LIMIT=8
TELEGRAM_CAPTION_MAX=1024
ADMIN_TOKEN=replace-with-long-random-token

# Product analytics. Leave POSTHOG_API_KEY empty to keep events local (pino only).
# Project API key (starts with "phc_") from PostHog Cloud → Project Settings.
POSTHOG_API_KEY=
POSTHOG_HOST=https://us.i.posthog.com
